{
  "hero": {
    "type": "object",
    "additionalProperties": false,
    "required": ["type"],
    "properties": {
      "type": { "const": "hero" },
      "title": { "type": "string", "default": "歡迎光臨", "x-editor": "text" },
      "subtitle": { "type": "string", "default": "", "x-editor": "text" },
      "image": { "type": "string", "default": "", "x-editor": "image" },
      "cta_text": { "type": "string", "default": "了解更多", "x-editor": "text" },
      "cta_href": { "type": "string", "default": "/", "x-editor": "text" }
    }
  },
  "rich_text": {
    "type": "object",
    "additionalProperties": false,
    "required": ["type"],
    "properties": {
      "type": { "const": "rich_text" },
      "html": { "type": "string", "default": "", "x-editor": "richtext" }
    }
  },
  "feature_grid": {
    "type": "object",
    "additionalProperties": false,
    "required": ["type"],
    "properties": {
      "type": { "const": "feature_grid" },
      "title": { "type": "string", "default": "特色", "x-editor": "text" },
      "items": {
        "type": "array",
        "default": [],
        "x-editor": "list",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "icon": { "type": "string", "default": "", "x-editor": "image" },
            "title": { "type": "string", "default": "", "x-editor": "text" },
            "text": { "type": "string", "default": "", "x-editor": "text" }
          }
        }
      }
    }
  },
  "cta": {
    "type": "object",
    "additionalProperties": false,
    "required": ["type"],
    "properties": {
      "type": { "const": "cta" },
      "text": { "type": "string", "default": "立即開始", "x-editor": "text" },
      "button_text": { "type": "string", "default": "聯絡我們", "x-editor": "text" },
      "button_href": { "type": "string", "default": "/about", "x-editor": "text" }
    }
  }
}

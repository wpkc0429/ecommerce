# ─── docker-compose (infra) ─────────────────────────────────────────────
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
POSTGRES_DB=ecommerce
POSTGRES_PORT=5432
REDIS_PORT=6379

# ─── api (Go) ───────────────────────────────────────────────────────────
APP_ENV=development
API_ADDR=:8080
LOG_LEVEL=info

DATABASE_URL=postgres://ecommerce:ecommerce@localhost:5432/ecommerce?sslmode=disable
# Atlas dev database: used only by `make migrate-gen` to replay+diff migrations.
DEV_DATABASE_URL=postgres://ecommerce:ecommerce@localhost:5432/ecommerce_dev?sslmode=disable
# Integration tests run against this database (wiped between tests).
TEST_DATABASE_URL=postgres://ecommerce:ecommerce@localhost:5432/ecommerce_test?sslmode=disable

REDIS_ADDR=localhost:6379

# JWT: admin and member systems use fully isolated secrets (design D9).
ADMIN_JWT_SECRET=dev-only-admin-secret-change-me
MEMBER_JWT_SECRET=dev-only-member-secret-change-me
JWT_ISSUER=ecommerce-api
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
PREVIEW_TOKEN_TTL=10m

# Initial platform administrator created by `make seed`.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin-change-me

# ─── web (storefront SSR) ───────────────────────────────────────────────
API_BASE_URL=http://localhost:8080
WEB_PORT=3000

# ─── admin (thin SPA) ───────────────────────────────────────────────────
ADMIN_PORT=3001
